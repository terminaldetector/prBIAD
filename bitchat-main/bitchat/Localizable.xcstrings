    "app_info.privacy.panic.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اضغط الشعار ثلاث مرات لمسح كل البيانات فوراً"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "লোগোতে তিনবার ট্যাপ করলে সঙ্গে সঙ্গে সব ডেটা মুছে যাবে"
          }
        },
        "de" : {
          "stringUnit" : {
