          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "लगो तीन पटक ट्याप गर्दा सबै डाटा तुरुन्त मेटिन्छ"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "tik drie keer op het logo om alle data direct te wissen"
          }
        },
        "pl" : {
          "stringUnit" : {
